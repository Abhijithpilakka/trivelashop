# Trivela — Environment Variables
# Copy this to .env.local and fill in values

# Backend API (optional — falls back to seed data if not set)
NEXT_PUBLIC_API_URL=

# WhatsApp number (digits only, with country code)
NEXT_PUBLIC_WA_NUMBER=919999999999

# Store config
NEXT_PUBLIC_STORE_NAME=TRIVELA
NEXT_PUBLIC_FREE_SHIP_MIN=1499
NEXT_PUBLIC_DEFAULT_SHIP=79
